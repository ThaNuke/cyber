# Backend Server Configuration
PORT=5000

# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Email Service (Gmail Configuration)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# Comma-separated allowed origins for CORS
FRONTEND_ORIGINS=http://localhost:5173

# Microsoft Entra ID (OIDC) - Login via university email
# Create an App Registration and set these values.
MS_TENANT_ID=your_tenant_id
MS_CLIENT_ID=your_app_client_id
MS_ALLOWED_DOMAINS=kmutt.ac.th,mail.kmutt.ac.th
JWT_SECRET=change-me-in-production

# Set true only if you want local email/password login enabled.
ALLOW_PASSWORD_LOGIN=false

# AES-256-GCM key for encrypting evaluation payload at rest (base64 of 32 bytes).
# Example (generate): node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
EVAL_ENCRYPTION_KEY=replace-with-32-byte-base64

# Cookie auth settings (httpOnly)
AUTH_COOKIE_NAME=auth_token
# In production, secure cookies must be true
COOKIE_SECURE=true
# If frontend and backend are on different domains, use SameSite=None (requires Secure)
COOKIE_SAMESITE=none
